# FitTech Mobile Environment Variables Template
# Copy this file to .env and replace the values

# API Configuration
# Use your computer's local IP if using physical device or Expo Go
# Use http://10.0.2.2:3000/api if using Android Emulator
# Use http://localhost:3000/api if using Web browser
EXPO_PUBLIC_API_URL=http://replace_with_your_ip:3000/api
